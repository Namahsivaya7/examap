type ExamPricing {
  price         Float           @default(0)
  currency      CurrencyCode    @default(INR)
  maxAttempts   Int             @default(5)
}

model Exam {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  createdAt       DateTime      @default(now()) 
  updatedAt       DateTime      @updatedAt 

  title           String
  subjectId       String        @db.ObjectId
  subject         Subject       @relation(fields: [subjectId], references: [id])
  benchmark       Float         @default(40.0) // In percent
  tags            String[]
  org             Organisation
  avatar          String?
  description     String?
  manualAssess    Boolean       @default(false)        // Cases where exam have an Assay type questions and need manual correction

  ownerId         String        @db.ObjectId
  owner           User          @relation(fields: [ownerId], references: [id])
  
  questionIds     String[]      @db.ObjectId
  questions       Question[]    @relation(fields: [questionIds], references: [id])

  status          ExamStatus    @default(Draft)

  timer           Int           @default(30) // Time in minutes to complete the exam

  stars           Star[]        @relation("ExamStars")
  star_count      Int           @default(0)

  attempts        Attempt[]     @relation("ExamAttempts")
  attempt_count   Int           @default(0)

  tests           Test[]
  pricing         ExamPricing?
  orders          Order[]
}

enum ResultStatus {
  Passed
  Failed
  NotAttemted
}

type ExamResult {
  status  ResultStatus
  score   Float
  total   Int
  each    Json // {[questionId]: boolean}
}

enum AttemptStatus {
  Created     // Default
  // ||
  // \/
  InProgress  // when startTime updates
  //  ||  
  //  \/
  Elapsed     // never submitted. 
  //  ||      
  //  ||      // Submitted - Manual or automatic submit
  //  \/
  InReview    // For exams that need manual correction
  //  ||
  //  \/
  Assessed    // If attempt is assessed eithe manually or automatic 
}

model Attempt {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  createdAt     DateTime        @default(now()) 
  updatedAt     DateTime        @updatedAt
  startTime     DateTime?
  userId        String          @db.ObjectId
  user          User            @relation(fields: [userId], references: [id])   
  examId        String          @db.ObjectId
  exam          Exam            @relation("ExamAttempts", fields: [examId], references: [id]) 
  responses     Json            @default("{}") // {[questionId]: Answer[]}
  result        ExamResult?
  deviatedCount Int             @default(0)
  status        AttemptStatus   @default(Created)
  testId        String?         @db.ObjectId
  test          Test?           @relation(fields: [testId], references: [id])
  orderId       String?         @db.ObjectId
  Order         Order?          @relation(fields: [orderId], references: [id])
}

enum TestStatus {
  Active
  InActive  // Doesn't take further attempts
}

model Test {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  createdAt     DateTime    @default(now()) 
  name          String 
  ownerId       String      @db.ObjectId
  owner         User        @relation(fields: [ownerId], references: [id])   
  examId        String      @db.ObjectId
  exam          Exam        @relation(fields: [examId], references: [id])   
  attempt_count Int         @default(0)
  attempts      Attempt[]
  status        TestStatus  @default(Active)
}

enum OrderStatus {
  Created
  Paid
  Failed
  Expired
}

model Order {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  createdAt     DateTime    @default(now()) 
  userId        String      @db.ObjectId
  user          User        @relation(fields: [userId], references: [id])   
  examId        String      @db.ObjectId
  exam          Exam        @relation(fields: [examId], references: [id])
  attempt_count Int         @default(0)
  attempts      Attempt[]
  status        OrderStatus @default(Created)
}
