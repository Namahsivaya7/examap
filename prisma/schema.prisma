// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum LoginType {
  Normal
  GitHub
  Gmail
  Facebook
}

model User {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  createdAt       DateTime    @default(now()) 
  updatedAt       DateTime    @updatedAt 
  email           String      @unique
  name            String
  emailVerified   Boolean     @default(false)
  password        String?
  phone           String?
  address         String?
  occupation      String?   
  loginType       LoginType   @default(Normal)
  avatar          String?
  exams           Exam[]
  stars           Star[]
  attempts        Attempt[]
  questions       Question[]
  tests           Test[]
  orders          Order[]
}

type Organisation {
  name        String
  address     String
}

type Option {
  id String
  label String
  isAnswer Boolean?
}

enum AnswerType {
  Essay 
  Single
  Multi
}

enum QuestionStatus {
  Public // Can be attach to any exam (Available in the library)
  Private // Attached to the specific exam
  InActive  // Archived, (not in use)
}

model Question {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  subjectId   String          @db.ObjectId
  subject     Subject         @relation(fields: [subjectId], references: [id])
  options     Option[]
  answer      String?     
  answerType  AnswerType 
  marks       Int             @default(1)
  status      QuestionStatus  @default(Public)
  userId      String          @db.ObjectId
  user        User            @relation(fields: [userId], references: [id])
  examIds     String[]        @db.ObjectId
  exams       Exam[]          @relation(fields: [examIds], references: [id])
}

model Star {
  id            String  @id @default(auto()) @map("_id") @db.ObjectId
  userId        String  @db.ObjectId  
  user          User    @relation(fields: [userId], references: [id])   
  examId        String  @db.ObjectId    
  exam          Exam    @relation("ExamStars", fields: [examId], references: [id]) 
}

model Subject {
  id            String  @id @default(auto()) @map("_id") @db.ObjectId
  name          String  @unique  
  description   String? @default("")
  exams         Exam[]
  questions     Question[]
}

enum ExamStatus {
  Draft
  Published
  Private
  Archived
}

